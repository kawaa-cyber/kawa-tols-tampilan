# ==================== ANIMATIONS ====================
class Animations:
    @staticmethod
    def loading(text="Loading", duration=2):
        anim = ["в Ӣ", "в ҷ", "в №", "в ё", "в ј", "в ҙ", "в Ұ", "в §", "в Ү", "в Ҹ"]
        end = time.time() + duration
        i = 0
        while time.time() < end:
            print(f"\r{Colors.CYAN}[{anim[i % len(anim)]}] {text}...{Colors.END}", end="")
            time.sleep(0.1)
            i += 1
        print()

    @staticmethod
    def matrix_rain(duration=3):
        chars = "01гӮўгӮӨгӮҰгӮЁгӮӘгӮ«гӮӯгӮҜгӮұгӮігӮөгӮ·гӮ№гӮ»гӮҪгӮҝгғҒгғ„гғҶгғҲ"
        end = time.time() + duration
        print(f"{Colors.GREEN}")
        while time.time() < end:
            line = ''.join(random.choice(chars) for _ in range(40))
            print(f"{line[:random.randint(20,40)]}")
            time.sleep(0.03)
        print(f"{Colors.END}")

    @staticmethod
    def progress_bar(title="Processing", total=30):
        print(f"{Colors.BOLD}{Colors.BLUE}{title}:{Colors.END}")
        for i in range(total + 1):
            bar = "в–Ҳ" * i + "в–‘" * (total - i)
            percent = (i / total) * 100
            print(f"\r{Colors.GREEN}[{bar}] {percent:.1f}%{Colors.END}", end="")
            time.sleep(0.05)
        print()

    @staticmethod
    def typing(text, delay=0.05):
        for char in text:
            print(char, end='', flush=True)
            time.sleep(delay)
        print()

